# ===== Frontend environment variables (Vercel) =====

# REQUIRED in production: the public URL of your Render backend (no trailing slash).
# Example: https://mumbai-brief-api.onrender.com
# Leave this BLANK for local dev — Vite proxies /api to localhost:8787 instead.
VITE_API_BASE_URL=

# Optional: override the dev proxy target (defaults to http://localhost:8787)
# VITE_DEV_API_TARGET=http://localhost:8787
