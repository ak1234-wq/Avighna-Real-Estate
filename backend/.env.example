# ===== Backend environment variables (Render) =====

# REQUIRED. Your Google Gemini API key. Get one at https://aistudio.google.com/apikey
# This single key powers BOTH the news feed and the Ask assistant (Gemini does the
# Google Search grounding / web search and returns real source citations).
GEMINI_API_KEY=AIza...your-key-here

# Optional. Model to use. Must support Google Search grounding. Default: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Optional. How long (ms) to cache each tab's feed before re-fetching. Default 600000 (10 min).
# FEED_CACHE_TTL_MS=600000

# Optional but recommended in production: lock CORS to your Vercel URL.
# Comma-separate multiple origins. Leave unset to allow all (dev only).
# FRONTEND_ORIGIN=https://your-app.vercel.app

# Render sets PORT automatically; no need to set it yourself.
# PORT=8787
