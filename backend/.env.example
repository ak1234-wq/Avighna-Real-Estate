# ===== Backend environment variables (Render) =====

# REQUIRED. Your Google Gemini API key (used only for summarization + Ask assistant).
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...your-key-here

# REQUIRED. Your Tavily API key (used for internet-wide news search).
# Get a free key at: https://app.tavily.com → Dashboard → API Keys
TAVILY_API_KEY=tvly-...your-key-here

# Optional. Gemini model to use. Default: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Optional. Cron expression for background news refresh. Default: every 30 min.
# FEED_REFRESH_CRON=*/30 * * * *

# Optional. SQLite DB file path. Default: ./data/news.db
# DB_PATH=./data/news.db

# Optional but recommended in production: lock CORS to your Vercel URL.
# Comma-separate multiple origins. Leave unset to allow all (dev only).
# FRONTEND_ORIGIN=https://your-app.vercel.app

# Render sets PORT automatically; no need to set it yourself.
# PORT=8787
